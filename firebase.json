{
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            ".env",
            "server.js",
            "prisma/**",
            "routes/**",
            "package.json",
            "package-lock.json",
            "*.log",
            "migrar-agora.js",
            "criar-admin.js",
            "teste-email.js",
            "propostas/**/optimize-*.js",
            "propostas/**/generate-*.js"
        ],
        "rewrites": [
            {
                "source": "/p/maple-bear",
                "destination": "/propostas/maple-bear/index.html"
            }
        ],
        "headers": [
            {
                "source": "/sw.js",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            },
            {
                "source": "/manifest.json",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache"
                    }
                ]
            },
            {
                "source": "/propostas/**/*.@(webp|avif|png|jpg|jpeg|svg|woff2)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000, immutable"
                    }
                ]
            },
            {
                "source": "/propostas/**/*.@(html|css|js)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=300, must-revalidate"
                    }
                ]
            }
        ]
    }
}
