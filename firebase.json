{
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            ".env",
            "server.js",
            "prisma/**",
            "routes/**",
            "package.json",
            "package-lock.json",
            "*.log",
            "migrar-agora.js",
            "criar-admin.js",
            "teste-email.js",
            "propostas/**/optimize-*.js",
            "propostas/**/generate-*.js"
        ],
        "rewrites": [
            {
                "source": "/p/maple-bear",
                "destination": "/propostas/maple-bear/index.html"
            },
            {
                "source": "/p/maple-bear-macae",
                "destination": "/propostas/maple-bear-macae/index.html"
            },
            {
                "source": "/p/crescer-mais",
                "destination": "/propostas/crescer-mais/index.html"
            },
            {
                "source": "/p/maple-bear-aguas-claras",
                "destination": "/propostas/maple-bear-aguas-claras/index.html"
            },
            {
                "source": "/p/maple-bear-uberaba",
                "destination": "/propostas/maple-bear-uberaba/index.html"
            },
            {
                "source": "/p/salesianos-bsb",
                "destination": "/propostas/salesianos/index.html"
            },
            {
                "source": "/p/disponiveis-20-06-2026",
                "destination": "/propostas/disponiveis-20-06-2026/index.html"
            },
            {
                "source": "/p/**",
                "destination": "/propostas/view.html"
            }
        ],
        "headers": [
            {
                "source": "/sw.js",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            },
            {
                "source": "/manifest.json",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache"
                    }
                ]
            },
            {
                "source": "/propostas/**/*.@(webp|avif|png|jpg|jpeg|svg|woff2)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000, immutable"
                    }
                ]
            },
            {
                "source": "/propostas/**/*.@(html|css|js)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=300, must-revalidate"
                    }
                ]
            },
            {
                "source": "/propostas/view.html",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, must-revalidate"
                    }
                ]
            },
            {
                "source": "/p/**",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=60, must-revalidate"
                    }
                ]
            }
        ]
    }
}
